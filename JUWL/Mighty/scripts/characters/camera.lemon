//# address-hook(0x01c11e) end(0x01c236)
function void UpdateCameraPositionY()
{
	if (isECFCharA0("JUWL-Mighty"))
	{
		u8 pId = getPId()
		if (mighty_cam_vlock[pId])
		{
			if (char.position.y.u16 + char.box_size.y > camera.position.y.u16 + getScreenHeight() || char.position.y.u16 - char.box_size.y <= camera.position.y.u16)
				mighty_cam_vlock[pId] = 0
			else
				mighty_cam_vlock[pId]--
			return
		}
	}
	
	base.UpdateCameraPositionY()
}