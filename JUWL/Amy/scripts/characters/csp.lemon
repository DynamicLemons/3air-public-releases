#if CHARACTER_SELECTION_PLUS_ACTIVE
function void SwapMode_dataSwap_globals()
{
	base.SwapMode_dataSwap_globals()
	
	u8 _ = amy_bounceLoss[0]
	for (u8 i < 0; i < csp_playerCount; ++i)
		amy_bounceLoss[i] = amy_bounceLoss[i + 1]
	amy_bounceLoss[csp_playerCount] = _

}

function bool SwapMode_abilityFreeSwap()
{
	return (isECFCharA1("JUWL-Amy")) ? true : base.SwapMode_abilityFreeSwap()
}
#endif